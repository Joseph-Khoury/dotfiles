+-- Fuzzy finding: files, text, LSP results, and selection UIs.
+return {
+    "nvim-telescope/telescope.nvim",
+    version = "*",
+    dependencies = {
+        "nvim-lua/plenary.nvim",
+        "nvim-tree/nvim-web-devicons",
