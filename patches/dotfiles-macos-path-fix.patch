diff --git a/common/shell/zsh/os/05-macos-paths.zsh b/common/shell/zsh/os/05-macos-paths.zsh
index 703e80e..6b7f838 100644
--- a/common/shell/zsh/os/05-macos-paths.zsh
+++ b/common/shell/zsh/os/05-macos-paths.zsh
@@ -1,13 +1,34 @@
 # macOS-specific PATH/bootstrap
+#
+# Apple Silicon Macs can have two Homebrew installations:
+#   /opt/homebrew  -> native arm64 Homebrew
+#   /usr/local     -> Intel/Rosetta Homebrew
+#
+# Do not load both shellenv blocks. Loading both can put the wrong brew/nvim on
+# PATH and can make compiled Neovim assets such as Treesitter parsers fail.
 
-# Homebrew Apple Silicon
-if [[ -x /opt/homebrew/bin/brew ]]; then
-  eval "$(/opt/homebrew/bin/brew shellenv)"
-fi
+case "$(uname -m)" in
+  arm64)
+    if [[ -x /opt/homebrew/bin/brew ]]; then
+      eval "$(/opt/homebrew/bin/brew shellenv)"
+    elif [[ -x /usr/local/bin/brew ]]; then
+      # Fallback only: useful on unusual systems, but not preferred on ARM Macs.
+      eval "$(/usr/local/bin/brew shellenv)"
+    fi
+    ;;
+  x86_64)
+    if [[ -x /usr/local/bin/brew ]]; then
+      eval "$(/usr/local/bin/brew shellenv)"
+    elif [[ -x /opt/homebrew/bin/brew ]]; then
+      eval "$(/opt/homebrew/bin/brew shellenv)"
+    fi
+    ;;
+esac
 
-# Homebrew Intel fallback
-if [[ -x /usr/local/bin/brew ]]; then
-  eval "$(/usr/local/bin/brew shellenv)"
-fi
+path=(
+  "$HOME/.cargo/bin"
+  $path
+)
 
+typeset -U path PATH
 export PATH
