+  local dest="$1"
+  if [[ -L "$dest" ]]; then
+    rm "$dest"
+  elif [[ -e "$dest" ]]; then
+    mv "$dest" "$dest.backup.$TS"
+    echo "Backed up: $dest -> $dest.backup.$TS"
   fi
